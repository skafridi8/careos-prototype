VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Server-only — used by /api functions, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Groq chatbot — server-only, used by /api/chat.js
GROQ_API_KEY=your-groq-api-key

# Stripe (TEST MODE keys only) — server-only, used by /api/stripe/*.js
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret

# Stripe price IDs — safe to expose to the browser (not secret), used on the Subscribe page
VITE_STRIPE_PRICE_MONTHLY=price_your-monthly-price-id
VITE_STRIPE_PRICE_YEARLY=price_your-yearly-price-id

# Optional — overrides the site origin used for Stripe success/cancel redirect URLs
# (falls back to the request's Origin header if unset)
SITE_URL=https://your-deployed-site.vercel.app
